{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",

  "include-component-in-tag": false,
  "include-v-in-tag": true,
  "separate-pull-requests": false,
  "changelog-path": "CHANGELOG.md",

  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "alidade",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,

      "extra-files": [
        { "type": "generic", "path": "Cargo.toml" },
        { "type": "generic", "path": "crates/alidade/Cargo.toml" },
        { "type": "generic", "path": "crates/alidade-core/Cargo.toml" },

        { "type": "generic", "path": "python/pyproject.toml" },
        { "type": "generic", "path": "python/src/alidade/__init__.py" },
        { "type": "generic", "path": "python/tests/test_smoke.py" },

        { "type": "json", "path": "package.json",                       "jsonpath": "$.version" },
        { "type": "json", "path": "app/package.json",                   "jsonpath": "$.version" },
        { "type": "json", "path": "packages/protocol/package.json",     "jsonpath": "$.version" },
        { "type": "json", "path": "npm/alidade/package.json",           "jsonpath": "$.version" }
      ]
    }
  }
}
