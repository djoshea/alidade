# Repo-wide ignores only. Component-specific ignores live in
# app/.gitignore and python/.gitignore.

# ── Rust (Cargo) — workspace-rooted; Cargo.lock is tracked. ──
target/

# ── Node (pnpm workspace) — node_modules can appear at the root and in any
#    workspace package; pnpm-lock.yaml is tracked at the root. ──
node_modules/

# ── Local / secrets ──
.env
.env.*
!.env.example

# ── OS / editor ──
.DS_Store
Thumbs.db
*.swp
.idea/
# .vscode/   ← uncomment if you don't want to share editor settings
