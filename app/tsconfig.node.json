{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,

    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo.node.json"
  },
  "include": ["vite.config.ts"]
}
