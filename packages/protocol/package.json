{
  "name": "@alidade-app/protocol",
  "version": "0.0.0",
  "description": "TypeScript wire-protocol types for alidade. Generated from the alidade-protocol Rust crate.",
  "license": "SEE LICENSE IN ../../LICENSE.md",
  "author": "Daniel J. O'Shea",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djoshea/alidade.git",
    "directory": "packages/protocol"
  },
  "homepage": "https://github.com/djoshea/alidade",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
